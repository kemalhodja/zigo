# Copy to .env.local when preparing hosted staging (Vercel + Supabase Cloud).
# Never commit real secrets. Rotate keys every 90 days — see docs/operational-security.md

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_SITE_URL=https://your-staging.vercel.app

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: apply bundled migrations from CLI (scripts/apply-cloud-migrations.mjs)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=true
ZIGO_BILLING_DEV_BYPASS=false
NEXT_PUBLIC_ZIGO_BILLING_DEV_BYPASS=false
STRIPE_PRICE_ID_ZIGO_PLUS=price_...
STRIPE_PRICE_STUDENT_MONTHLY=price_...
STRIPE_PRICE_STUDENT_YEARLY=price_...
STRIPE_PRICE_PARENT_MONTHLY=price_...
STRIPE_PRICE_TEACHER_MONTHLY=price_...
STRIPE_PRICE_INSTITUTION_YEARLY=price_...
STRIPE_PRICE_PLATFORM_YEARLY=price_...
STRIPE_COUPON_CAMPAIGN_75OFF=zigo-yaz-2026-75off

# Auth hardening (hosted staging / production)
ZIGO_REQUIRE_EMAIL_CONFIRM=true
ZIGO_REQUIRE_STUDENT_DOCUMENT=true
ZIGO_REQUIRE_RECAPTCHA=true
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

CAPACITOR_SERVER_URL=https://your-staging.vercel.app

# Monitoring (optional)
# ZIGO_HEALTH_URL=https://your-staging.vercel.app
# SENTRY_DSN=https://...@sentry.io/...
