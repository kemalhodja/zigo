# Production / Vercel environment template
# Copy to Vercel project env (or .env.production.local for local hosted testing).
# Never commit filled secrets.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://zigo.app
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Stripe — create products/prices for each plan in Dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=true
ZIGO_BILLING_DEV_BYPASS=false
NEXT_PUBLIC_ZIGO_BILLING_DEV_BYPASS=false
STRIPE_PRICE_ID_ZIGO_PLUS=price_fallback
STRIPE_PRICE_STUDENT_MONTHLY=price_...
STRIPE_PRICE_STUDENT_SEMIANNUAL=price_...
STRIPE_PRICE_STUDENT_YEARLY=price_...
STRIPE_PRICE_PARENT_MONTHLY=price_...
STRIPE_PRICE_PARENT_SEMIANNUAL=price_...
STRIPE_PRICE_PARENT_YEARLY=price_...
STRIPE_PRICE_FAMILY_MONTHLY=price_...
STRIPE_PRICE_FAMILY_SEMIANNUAL=price_...
STRIPE_PRICE_FAMILY_YEARLY=price_...
STRIPE_PRICE_TEACHER_MONTHLY=price_...
STRIPE_PRICE_TEACHER_SEMIANNUAL=price_...
STRIPE_PRICE_TEACHER_YEARLY=price_...
STRIPE_PRICE_INSTITUTION_MONTHLY=price_...
STRIPE_PRICE_INSTITUTION_SEMIANNUAL=price_...
STRIPE_PRICE_INSTITUTION_YEARLY=price_...
STRIPE_PRICE_PLATFORM_MONTHLY=price_...
STRIPE_PRICE_PLATFORM_SEMIANNUAL=price_...
STRIPE_PRICE_PLATFORM_YEARLY=price_...
STRIPE_COUPON_CAMPAIGN_75OFF=zigo-yaz-2026-75off

# Auth hardening
ZIGO_REQUIRE_EMAIL_CONFIRM=true
ZIGO_REQUIRE_STUDENT_DOCUMENT=true
ZIGO_REQUIRE_RECAPTCHA=true
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Mobile
CAPACITOR_SERVER_URL=https://zigo.app

# Optional
NEXT_PUBLIC_VIDEO_CDN_BASE=
NEXT_PUBLIC_LOCALE=tr
ZIGO_HEALTH_URL=https://zigo.app
