# Copy to android/keystore.properties (never commit the real file).
# Generate a release keystore first:
#   keytool -genkey -v -keystore zigo-release.keystore -alias zigo -keyalg RSA -keysize 2048 -validity 10000

storeFile=zigo-release.keystore
storePassword=your_store_password
keyAlias=zigo
keyPassword=your_key_password
