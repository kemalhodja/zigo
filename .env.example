NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# UI language: tr (default) or en
NEXT_PUBLIC_LOCALE=tr

# Server-only. Used by /api/setup/health and npm run test:live.
# Never expose this key to the browser or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URL for npm run migrations:cloud / migrations:pending
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Stripe billing (Zigo Plus). Server keys stay private; public flags gate checkout UI.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_ZIGO_PLUS=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=false
NEXT_PUBLIC_ZIGO_BILLING_DEV_BYPASS=false
ZIGO_BILLING_DEV_BYPASS=false

# Local QA: 90-second Pomodoro when true (also auto on 127.0.0.1 Supabase).
NEXT_PUBLIC_FOCUS_DEMO_SECONDS=false

# Optional video CDN base for production micro-lesson delivery (see docs/video-delivery.md).
NEXT_PUBLIC_VIDEO_CDN_BASE=

# Optional HLS adaptive streaming flag (requires CDN/HLS pipeline).
NEXT_PUBLIC_VIDEO_HLS_ENABLED=false

# Optional Web Push VAPID public key (scaffold; full push requires service worker wiring).
NEXT_PUBLIC_PUSH_VAPID_KEY=

# Google reCAPTCHA v3 (sign-up). Server secret stays private.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
ZIGO_REQUIRE_RECAPTCHA=true
ZIGO_REQUIRE_EMAIL_CONFIRM=true
ZIGO_REQUIRE_STUDENT_DOCUMENT=true

# Optional AI moderation provider (falls back to keyword filter when unset).
ZIGO_AI_MODERATION_URL=
ZIGO_AI_MODERATION_KEY=
ZIGO_AI_MODERATION_TIMEOUT_MS=4000

# Scorecard: set to 1 when Supabase + dev server are running for full live probes.
# ZIGO_RUN_LIVE_TESTS=1
# Debug over USB reverse:
# CAPACITOR_SERVER_URL=http://localhost:3000
# Production hosted app:
# CAPACITOR_SERVER_URL=https://zigo.app
CAPACITOR_SERVER_URL=
